# Copy this file to .env and fill in real values for local development.

NODE_ENV=development
PORT=4000

# Postgres — matches the docker-compose service below
DATABASE_URL="postgresql://itamil:itamil_dev@localhost:5432/itamil_recruit?schema=public"

# JWT — generate a long random string for each environment
# Example: `openssl rand -hex 32`
JWT_ACCESS_SECRET="replace_me_with_64_random_hex_chars"
JWT_REFRESH_SECRET="replace_me_with_a_different_64_random_hex_chars"
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# CORS — comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# OTP — leave provider blank in dev to log codes to stdout
OTP_PROVIDER=
OTP_TTL_MIN=10

# Cookie security — set true behind HTTPS (i.e. production)
COOKIE_SECURE=false

# Copy this file to .env and fill in real values for local development.

NODE_ENV=development
PORT=4000

# Postgres — matches the docker-compose service below
DATABASE_URL="postgresql://itamil:itamil_dev@localhost:5432/itamil_recruit?schema=public"

# JWT — generate a long random string for each environment
# Example: `openssl rand -hex 32`
JWT_ACCESS_SECRET="replace_me_with_64_random_hex_chars"
JWT_REFRESH_SECRET="replace_me_with_a_different_64_random_hex_chars"
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# CORS — comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# OTP
OTP_PROVIDER=
OTP_TTL_MIN=10
# TEST ONLY — echo OTP codes in API responses (never in prod)
ENABLE_DEV_OTP=false

# Cookie security — set true behind HTTPS (i.e. production)
COOKIE_SECURE=false

# -------- Email (nodemailer via SMTP) --------
# Recommended: Zoho Mail Free with a mailbox on itamilrecruit.net.
# Any SMTP relay works — Zoho, Brevo, M365, SES, etc.
# Leave SMTP_HOST blank in dev to log emails instead of sending.
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_USER=noreply@itamilrecruit.net
SMTP_PASS=<app-password-from-provider>
SMTP_FROM="i-Tamil Recruit <noreply@itamilrecruit.net>"

# Default Reply-To header — lets you send from a clean noreply@ address
# while user replies still land in a monitored inbox (support / hello).
EMAIL_REPLY_TO=hello@itamilrecruit.net

# Every notification (signup / job / application / moderation) cc's these
# addresses so ops can watch platform activity in one inbox.
# Comma-separated for multiple.
ADMIN_NOTIFICATIONS_EMAIL=websitedevelopment@itamilrecruit.net

# Public URL — used to build absolute links in outbound emails
PUBLIC_APP_URL=https://itamilrecruit.net

# -------- Super-admin seed --------
# Comma-separated list of super-admin emails to seed at boot. First boot
# after adding a new email will create the row; subsequent boots are no-ops.
SUPER_ADMIN_EMAIL=websitedevelopment@itamilrecruit.net,super@itr.com
SUPER_ADMIN_NAME="Super Admin"

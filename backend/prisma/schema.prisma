// i-Tamil Recruit — database schema
//
// Source of truth for every entity the API and admin module need.
// Run `npm run db:migrate` after editing to generate a migration.
//
// Conventions:
//   * Every table has id (cuid), createdAt, updatedAt. Soft-delete via deletedAt.
//   * Money is stored in paise (integer) to avoid floating-point drift.
//   * Lists of strings (skills, languages, departments) are JSON columns
//     because MySQL doesn't have native scalar arrays. Normalize later if
//     filter/search performance demands it.
//   * Moderation status lives on the entity itself, not a separate queue
//     table — the admin queue is just `WHERE moderationStatus = PENDING`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------------------------- //
// Users & auth
// -------------------------------------------------------------------- //

enum UserRole {
  CANDIDATE
  EMPLOYER
  ADMIN
  SUPER_ADMIN
  STAFF
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id             String    @id @default(cuid())
  role           UserRole
  email          String    @unique
  emailVerified  Boolean   @default(false)
  mobile         String?
  mobileVerified Boolean   @default(false)
  name           String
  passwordHash   String? // optional — OTP-only flow leaves this null

  // Staff-flow additions:
  //   sharedPassword — plain-text password chosen at bootstrap so
  //     super-admin (for staff) or staff (for the employers they
  //     provision) can reveal and share the credential. The passwordHash
  //     column above still holds the bcrypt for actual auth.
  //   deactivated — soft-disable a staff account without deleting audit
  //     history. Set true → passwordLogin refuses.
  //   createdByStaffId — for employer users, points back at the staff
  //     user who provisioned them. NULL for self-registered employers.
  //   jobsPostedByStaff — reverse relation surfaces "employers I created"
  //     and "jobs I posted for other employers".
  sharedPassword    String?
  deactivated       Boolean  @default(false)
  createdByStaffId  String?
  createdByStaff    User?    @relation("StaffProvisioned", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  provisionedUsers  User[]   @relation("StaffProvisioned")
  jobsPostedByStaff Job[]    @relation("StaffPostedJobs")

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  lastSeenAt     DateTime?

  candidateProfile CandidateProfile?
  employerProfile  EmployerProfile?
  jobsPosted       Job[]             @relation("EmployerJobs")
  applications     Application[]     @relation("CandidateApplications")
  savedJobs        SavedJob[]
  subscriptions    Subscription[]
  auditLogs        AuditLog[]        @relation("ActorLogs")
  otps             OtpToken[]

  @@index([role])
  @@index([deletedAt])
  @@index([createdByStaffId])
  @@map("users")
}

enum OtpPurpose {
  REGISTER
  LOGIN
  EMAIL_VERIFY
  MOBILE_VERIFY
  PASSWORD_RESET
}

model OtpToken {
  id        String     @id @default(cuid())
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  purpose   OtpPurpose
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int        @default(0)
  ip        String?
  userAgent String?    @db.VarChar(512)
  createdAt DateTime   @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
  @@map("otp_tokens")
}

// -------------------------------------------------------------------- //
// Candidate
// -------------------------------------------------------------------- //

enum CandidateType {
  FRESHER
  EXPERIENCED
}

enum FieldKind {
  IT
  NON_IT
}

enum InternOrJob {
  INTERN
  JOB
}

enum TemplateId {
  CLASSIC
  MODERN
  CREATIVE
  CORPORATE
  TECH_MONO
}

model CandidateProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Photo — currently base64 data URL (matches frontend). Migrate to S3/
  // Cloudinary later and revert to a short URL column.
  photoUrl        String? @db.Text
  alternateMobile String?

  // Current address — structured location
  currentDistrictId String?
  currentTalukId    String?
  currentLat        Float?
  currentLng        Float?
  currentPincode    String?
  currentStreet     String?   @db.VarChar(255) // private; never returned in public views

  // Preferred work location — multi-select of district IDs (the candidate's
  // home district hierarchy is the only anchor; preferred is purely a list
  // of districts they're open to working in).
  preferredDistricts  Json    @default("[]") // string[] of district IDs

  // Legacy single-anchor preferred fields — kept while the matcher still
  // reads a single (lat, lng) pair for "Near preferred" scoring. We mirror
  // the first entry of preferredDistricts into these.
  preferredDistrictId String?
  preferredTalukId    String?
  preferredLat        Float?
  preferredLng        Float?
  preferredPincode    String?
  preferredLocation   String? // legacy display label, derived from structured pickers

  // Ambitions
  shortTermAmbition String? @db.Text
  longTermAmbition  String? @db.Text

  // Fresher vs experienced branching
  type              CandidateType?
  internOrJob       InternOrJob?
  field             FieldKind?
  itSpecialization  String?
  itLanguages       Json? // string[]
  nonItDepartments  Json? // string[]
  yearsOfExperience Int?
  topSkills         Json? // string[]

  // Showcase links — array of { label, url }. Optional. Free-form so the
  // candidate can add LinkedIn, Portfolio, GitHub, Behance, anything.
  links             Json     @default("[]") // { label: string; url: string }[]

  // Template picked on preview step
  selectedTemplateId TemplateId?

  // Admin moderation
  moderationStatus ModerationStatus @default(PENDING)
  moderationNotes  String?          @db.Text
  moderatedAt      DateTime?
  moderatedById    String?

  education    Education[]
  experiences  Experience[]
  applications Application[] @relation("CandidateAppsViaProfile")

  @@index([moderationStatus])
  @@index([type, field])
  @@index([currentDistrictId])
  @@index([preferredDistrictId])
  @@map("candidate_profiles")
}

enum EducationLevel {
  TENTH
  TWELFTH
  DIPLOMA
  UG
  PG
  MPHIL
  PHD
  OTHER
}

model Education {
  id          String           @id @default(cuid())
  profileId   String
  profile     CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  level       EducationLevel
  enabled     Boolean          @default(true)
  percentage  Float?
  passedOutYear Int?
  thesis      String? @db.Text // PhD only
  courseName  String? // OTHER only
  institution String?
  // Where the candidate studied — district + pincode. Both optional so the
  // form stays low-friction; useful for "studied near my city" filters.
  districtId  String?
  pincode     String?
  createdAt   DateTime @default(now())

  @@unique([profileId, level])
  @@map("education")
}

model Experience {
  id        String           @id @default(cuid())
  profileId String
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company   String
  role      String
  fromDate  String // YYYY-MM (keep loose — we render it back as-is)
  toDate    String? // null = present
  createdAt DateTime         @default(now())

  projects  ExperienceProject[]

  @@index([profileId])
  @@map("experiences")
}

/**
 * One project entry inside an Experience row. Lets the candidate showcase
 * concrete work done at each company — name + brief + skills used + an
 * optional public link (GitHub, case study, deployed app, etc.).
 * All fields optional except name so the form stays low-friction.
 */
model ExperienceProject {
  id           String     @id @default(cuid())
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  name         String
  description  String?    @db.Text
  skills       Json       @default("[]") // string[]
  showcaseUrl  String?    @db.VarChar(512)
  createdAt    DateTime   @default(now())

  @@index([experienceId])
  @@map("experience_projects")
}

// -------------------------------------------------------------------- //
// Employer
// -------------------------------------------------------------------- //

enum CompanySize {
  SME       // 1–50 employees
  LARGE     // >50 employees
}

model EmployerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  companySize CompanySize @default(SME)
  industry    String?
  website     String?
  about       String?  @db.Text
  logoUrl     String?  @db.Text // base64 data URL (up to ~250KB) or CDN URL when object storage lands

  // Address
  districtId  String?
  talukId     String?
  lat         Float?
  lng         Float?
  pincode     String?

  // Admin moderation
  moderationStatus ModerationStatus @default(PENDING)
  moderationNotes  String?          @db.Text
  moderatedAt      DateTime?
  moderatedById    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moderationStatus])
  @@map("employer_profiles")
}

// -------------------------------------------------------------------- //
// Jobs
// -------------------------------------------------------------------- //

enum JobField {
  IT
  NON_IT
}

enum JobType {
  INTERNSHIP_TRAINING
  APPRENTICE
  FULL_TIME
  PART_TIME
  GIG_DELIVERY   // gig employment — delivery partners, cab drivers, etc.
  CONTRACT
  CONSULTANT
  FREELANCER
}

enum JobExperience {
  FRESHER
  EXPERIENCED
  ANY
}

enum JobStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
}

model Job {
  id           String        @id @default(cuid())
  employerId   String
  employer     User          @relation("EmployerJobs", fields: [employerId], references: [id], onDelete: Cascade)
  employerName String        // denormalized for fast list rendering

  // Set when the job was posted by a staff user on behalf of the employer;
  // null when the employer posted it themselves. Powers "Jobs I've posted"
  // on the staff dashboard.
  postedByStaffId String?
  postedByStaff   User?      @relation("StaffPostedJobs", fields: [postedByStaffId], references: [id], onDelete: SetNull)
  title        String
  description  String        @db.Text
  // Location
  location     String        // legacy display label
  districtId   String?
  talukId      String?
  lat          Float?
  lng          Float?
  pincode      String?
  street       String?       @db.VarChar(255) // private
  // Categorisation
  field        JobField
  type         JobType
  experience   JobExperience
  yearsMin     Int?
  yearsMax     Int?
  salaryRange  String?
  skills       Json          // string[]
  benefits     Json          @default("[]") // JobBenefit[] (strict enum, validated at API boundary)
  contactEmail String?       @db.VarChar(254) // optional hiring contact, distinct from employer login
  // Lifecycle
  status            JobStatus        @default(ACTIVE)
  moderationStatus  ModerationStatus @default(PENDING)
  moderationNotes   String?          @db.Text
  moderatedAt       DateTime?
  moderatedById     String?
  postedAt          DateTime         @default(now())
  // Listing lifecycle — jobs are live for 45 days from postedAt. Once
  // expiresAt is in the past the public feed hides them; the employer sees
  // an "Expired · Repost" state on their own dashboard.
  expiresAt         DateTime         @default(dbgenerated("now() + interval '45 days'"))
  closedAt          DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  applications Application[]
  savedBy      SavedJob[]

  @@index([status, moderationStatus])
  @@index([field, type, experience])
  @@index([districtId])
  @@index([employerId])
  @@index([postedAt])
  @@index([expiresAt])
  @@map("jobs")
}

enum ApplicationStatus {
  APPLIED
  VIEWED
  SHORTLISTED
  INTERVIEW
  REJECTED
  HIRED
  WITHDRAWN
}

model Application {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   User              @relation("CandidateApplications", fields: [candidateId], references: [id], onDelete: Cascade)
  profileId   String? // optional snapshot ref
  profile     CandidateProfile? @relation("CandidateAppsViaProfile", fields: [profileId], references: [id])

  status      ApplicationStatus @default(APPLIED)
  matchScore  Int? // cached at time of apply for analytics
  coverNote   String?           @db.Text
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, candidateId])
  @@index([candidateId])
  @@index([status])
  @@map("applications")
}

model SavedJob {
  id          String   @id @default(cuid())
  candidateId String
  candidate   User     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  savedAt     DateTime @default(now())

  @@unique([candidateId, jobId])
  @@map("saved_jobs")
}

// -------------------------------------------------------------------- //
// Subscriptions & plans
// -------------------------------------------------------------------- //

enum PlanAudience {
  CANDIDATE
  EMPLOYER_SME
  EMPLOYER_LARGE
}

model Plan {
  id           String       @id @default(cuid())
  key          String       @unique // e.g. "candidate_45d", "emp_sme_9d"
  label        String
  audience     PlanAudience
  durationDays Int
  priceInPaise Int          // base price ex-GST
  gstApplies   Boolean      @default(true)
  active       Boolean      @default(true)
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Subscription {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId            String
  plan              Plan          @relation(fields: [planId], references: [id])
  startedAt         DateTime      @default(now())
  expiresAt         DateTime
  // Payment — Razorpay two-step flow:
  //   order created  → razorpayOrderId set, paymentStatus=PENDING
  //   user pays      → razorpayPaymentId set on /verify or webhook,
  //                    paymentStatus=PAID + paidAt stamped
  //   admin refunds  → razorpayRefundId set, paymentStatus=REFUNDED
  paymentStatus     PaymentStatus @default(PENDING)
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?       @unique
  razorpayRefundId  String?
  amountInPaise     Int
  gstInPaise        Int           @default(0)
  totalInPaise      Int
  invoiceNumber     String?       @unique
  invoiceUrl        String?       @db.Text // Razorpay-hosted invoice PDF
  paidAt            DateTime?
  refundedAt        DateTime?
  refundRef         String?
  refundedById      String?
  refundReason      String?       @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, expiresAt])
  @@index([paymentStatus])
  @@map("subscriptions")
}

// -------------------------------------------------------------------- //
// Admin: audit log
// -------------------------------------------------------------------- //

enum AuditAction {
  USER_CREATED
  USER_LOGIN
  USER_LOGOUT
  USER_DELETED
  PROFILE_APPROVED
  PROFILE_REJECTED
  JOB_APPROVED
  JOB_REJECTED
  JOB_DELETED
  PLAN_CREATED
  PLAN_UPDATED
  PLAN_DELETED
  SUBSCRIPTION_REFUNDED
  ADMIN_NOTE_ADDED
  PRICING_CHANGED
  SYSTEM_SETTING_CHANGED
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  actor      User?       @relation("ActorLogs", fields: [actorId], references: [id])
  actorRole  UserRole?
  action     AuditAction
  targetType String? // e.g. "user", "job", "subscription"
  targetId   String?
  payload    Json? // freeform context (old/new values, notes, etc.)
  ip         String?
  userAgent  String?     @db.VarChar(512)
  createdAt  DateTime    @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}
